// Training data for the neural network
const trainingData = {
    javascript: [
        'function factorial(n) {\n    if (n === 0 || n === 1) {\n        return 1;\n    }\n    return n * factorial(n - 1);\n}\nconsole.log(factorial(5));',
        'console.log("Hello, World!");',
        'function sumArray(arr) {\n    return arr.reduce((sum, num) => sum + num, 0);\n}\nconst numbers = [1, 2, 3, 4, 5];\nconsole.log(sumArray(numbers));'
    ],
    python: [
        'def factorial(n):\n    if n == 0 or n == 1:\n        return 1\n    return n * factorial(n - 1)\nprint(factorial(5))',
        'print("Hello, World!")',
        'def sum_list(lst):\n    return sum(lst)\nnumbers = [1, 2, 3, 4, 5]\nprint(sum_list(numbers))'
    ],
    html: [
        '<!DOCTYPE html>\n<html lang="en">\n<head>\n    <meta charset="UTF-8">\n    <title>Example</title>\n</head>\n<body>\n    <h1>Hello</h1>\n</body>\n</html>',
        '<form action="/submit" method="post">\n    <input type="text" name="name">\n    <button type="submit">Submit</button>\n</form>'
    ],
    css: [
        'body {\n    font-family: Arial;\n    margin: 0;\n}\n.button {\n    background: blue;\n    color: white;\n}',
        '.container {\n    max-width: 800px;\n    margin: 0 auto;\n}'
    ],
    java: [
        'public class Hello {\n    public static void main(String[] args) {\n        System.out.println("Hello, World!");\n    }\n}',
        'public class Factorial {\n    public static int factorial(int n) {\n        if (n == 0) return 1;\n        return n * factorial(n-1);\n    }\n}'
    ],
    cpp: [
        '#include <iostream>\nint main() {\n    std::cout << "Hello, World!" << std::endl;\n    return 0;\n}',
        '#include <iostream>\nint factorial(int n) {\n    if (n == 0) return 1;\n    return n * factorial(n-1);\n}\nint main() {\n    std::cout << factorial(5) << std::endl;\n}'
    ]
};

// Neural network model
let model;
let charToIndex = {};
let indexToChar = {};
let vocabSize;

// Add error handling to model initialization
async function initModel() {
    try {
        // Create vocabulary
        const allChars = new Set();
        Object.values(trainingData).flat().forEach(code => {
            for (let char of code) {
                allChars.add(char);
            }
        });

        const chars = Array.from(allChars).sort();
        vocabSize = chars.length;

        chars.forEach((char, index) => {
            charToIndex[char] = index;
            indexToChar[index] = char;
        });

        // Create optimized model with 5 hidden layers and 512 neurons each (balanced performance)
        model = tf.sequential();
        model.add(tf.layers.lstm({
            units: 512,
            inputShape: [null, vocabSize],
            returnSequences: true,
            kernelInitializer: 'glorotNormal', // Faster initializer
            recurrentInitializer: 'glorotNormal'
        }));
        model.add(tf.layers.lstm({
            units: 512,
            returnSequences: true,
            kernelInitializer: 'glorotNormal',
            recurrentInitializer: 'glorotNormal'
        }));
        model.add(tf.layers.lstm({
            units: 512,
            returnSequences: true,
            kernelInitializer: 'glorotNormal',
            recurrentInitializer: 'glorotNormal'
        }));
        model.add(tf.layers.lstm({
            units: 512,
            returnSequences: true,
            kernelInitializer: 'glorotNormal',
            recurrentInitializer: 'glorotNormal'
        }));
        model.add(tf.layers.lstm({
            units: 512,
            returnSequences: true,
            kernelInitializer: 'glorotNormal',
            recurrentInitializer: 'glorotNormal'
        }));
        model.add(tf.layers.dense({
            units: vocabSize,
            activation: 'softmax',
            kernelInitializer: 'glorotNormal'
        }));

        model.compile({optimizer: 'adam', loss: 'categoricalCrossentropy'});

        console.log('Model initialized with 5 hidden layers and 512 neurons each (optimized)');
    } catch (error) {
        console.error('Error during model initialization:', error);
        throw new Error('Model initialization failed');
    }
}

// Add error handling to model training
async function trainModel(language) {
    try {
        if (!trainingData[language]) {
            throw new Error(`No training data available for language: ${language}`);
        }

        const sequences = [];
        const nextChars = [];

        trainingData[language].forEach(code => {
            for (let i = 0; i < code.length - 1; i++) {
                sequences.push(code.substring(0, i + 1));
                nextChars.push(code[i + 1]);
            }
        });

        // Prepare training data
        const xTrain = [];
        const yTrain = [];

        sequences.forEach((seq, idx) => {
            const x = Array(vocabSize).fill(0);
            const y = Array(vocabSize).fill(0);

            if (seq.length > 0) {
                x[charToIndex[seq[seq.length - 1]]] = 1;
            }
            y[charToIndex[nextChars[idx]]] = 1;

            xTrain.push(x);
            yTrain.push(y);
        });

        const xs = tf.tensor2d(xTrain, [xTrain.length, vocabSize]);
        const ys = tf.tensor2d(yTrain, [yTrain.length, vocabSize]);

        console.log(`Training model with ${xTrain.length} samples...`);
        await model.fit(xs, ys, {epochs: 1, batchSize: 16}); // Reduced batch size for memory

        xs.dispose();
        ys.dispose();

        console.log('Model trained for', language);
    } catch (error) {
        console.error('Error during model training:', error);
        throw new Error('Model training failed');
    }
}

// Enhanced logging for debugging
async function generateCodeWithNN(prompt, language, onProgress) {
    try {
        if (!model) {
            console.log('Model not initialized. Initializing now...');
            if (onProgress) onProgress('Initializing Neural Network...');
            await initModel();
        }

        console.log(`Training model for language: ${language}`);
        if (onProgress) onProgress('Training Neural Network...');
        await trainModel(language);

        if (onProgress) onProgress('Generating Code...');
        let generated = prompt;
        const maxLength = 200;

        for (let i = 0; i < maxLength; i++) {
            const input = Array(vocabSize).fill(0);
            if (generated.length > 0) {
                const lastChar = generated[generated.length - 1];
                if (charToIndex[lastChar] !== undefined) {
                    input[charToIndex[lastChar]] = 1;
                } else {
                    console.warn(`Character '${lastChar}' not in vocabulary.`);
                }
            }

            const prediction = model.predict(tf.tensor2d([input], [1, vocabSize]));
            const probabilities = await prediction.data();

            // Sample from distribution
            const randomIndex = sampleFromDistribution(probabilities);
            const nextChar = indexToChar[randomIndex];

            if (nextChar === '\n' && generated.endsWith('\n\n')) break;
            generated += nextChar;

            prediction.dispose();
        }

        console.log('Generated code:', generated);
        return generated;
    } catch (error) {
        console.error('Error during code generation:', error);
        throw new Error('Code generation failed');
    }
}

// Helper function to sample from probability distribution
function sampleFromDistribution(probs) {
    const rand = Math.random();
    let cumulative = 0;
    for (let i = 0; i < probs.length; i++) {
        cumulative += probs[i];
        if (rand < cumulative) return i;
    }
    return probs.length - 1;
}

// Mock neural network code editing function
function editCodeWithNeuralNetwork(code, language) {
    // Simulate neural network processing - add comments, optimize, etc.
    let editedCode = code;
    
    if (language === 'javascript') {
        // Add JSDoc comments
        editedCode = editedCode.replace(/function (\w+)/g, '/**\n * Function description\n * @param {*} params\n * @returns {*}\n */\nfunction $1');
        
        // Optimize simple patterns
        editedCode = editedCode.replace(/if \((\w+) === 0 \|\| (\w+) === 1\)/g, 'if ($1 === 0 || $1 === 1)');
        
        // Add error handling
        if (editedCode.includes('console.log')) {
            editedCode = editedCode.replace(/console\.log\((.+)\);/g, 'try {\n    console.log($1);\n} catch (error) {\n    console.error("Error logging:", error);\n}');
        }
    } else if (language === 'python') {
        // Add docstrings
        editedCode = editedCode.replace(/def (\w+)/g, 'def $1:\n    """\n    Function description\n    """');
        
        // Add type hints (simplified)
        editedCode = editedCode.replace(/def (\w+)\((\w+)\):/g, 'def $1($2: int) -> int:');
        
        // Add error handling
        if (editedCode.includes('print(')) {
            editedCode = editedCode.replace(/print\((.+)\)/g, 'try:\n    print($1)\nexcept Exception as e:\n    print(f"Error: {e}")');
        }
    } else if (language === 'html') {
        // Add semantic structure
        if (!editedCode.includes('<main>')) {
            editedCode = editedCode.replace(/(<body>)/, '$1\n    <main>');
            editedCode = editedCode.replace(/(<\/body>)/, '    </main>\n$1');
        }
        
        // Add meta tags
        if (!editedCode.includes('<meta name="description"')) {
            editedCode = editedCode.replace(/(<title>.*<\/title>)/, '$1\n    <meta name="description" content="Generated HTML page">');
        }
    } else if (language === 'css') {
        // Add vendor prefixes (simplified)
        editedCode = editedCode.replace(/border-radius:/g, '-webkit-border-radius: $1;\n    border-radius:');
        
        // Optimize selectors
        editedCode = editedCode.replace(/\.(\w+) \.(\w+)/g, '.$1.$2');
    } else if (language === 'java') {
        // Add JavaDoc
        editedCode = editedCode.replace(/public class (\w+)/g, '/**\n * Class description\n */\npublic class $1');
        
        // Add exception handling
        if (editedCode.includes('System.out.println')) {
            editedCode = editedCode.replace(/System\.out\.println\((.+)\);/g, 'try {\n            System.out.println($1);\n        } catch (Exception e) {\n            System.err.println("Error: " + e.getMessage());\n        }');
        }
    } else if (language === 'cpp') {
        // Add Doxygen comments
        editedCode = editedCode.replace(/int main\(\)/g, '/**\n * @brief Main function\n * @return int\n */\nint main()');
        
        // Add error checking
        if (editedCode.includes('std::cout')) {
            editedCode = editedCode.replace(/std::cout << (.+) << std::endl;/g, 'try {\n        std::cout << $1 << std::endl;\n    } catch (const std::exception& e) {\n        std::cerr << "Error: " << e.what() << std::endl;\n    }');
        }
    }
    
    return editedCode;
}

