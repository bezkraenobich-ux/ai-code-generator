// DOM elements
const generateBtn = document.getElementById('generate-btn');
const codeOutput = document.getElementById('code-output');
const copyBtn = document.getElementById('copy-btn');
const downloadBtn = document.getElementById('download-btn');
const saveBtn = document.getElementById('save-btn');
const editBtn = document.getElementById('edit-btn');
const languageSelect = document.getElementById('language');
const promptTextarea = document.getElementById('prompt');
const fileList = document.getElementById('file-list');
const neuralCanvas = document.getElementById('neural-canvas');
const startVizBtn = document.getElementById('start-viz-btn');
const stopVizBtn = document.getElementById('stop-viz-btn');

// Canvas context
const ctx = neuralCanvas.getContext('2d');

// Visualization variables
let animationId = null;
let isVisualizing = false;

// Saved files storage
let savedFiles = [];

// Canvas visualization functions
function drawNeuralNetwork() {
    if (!ctx) return;
    
    // Clear canvas
    ctx.clearRect(0, 0, neuralCanvas.width, neuralCanvas.height);
    
    // Draw neural network layers (5 hidden + output)
    const layers = [512, 512, 512, 512, 512, vocabSize || 50];
    const layerSpacing = neuralCanvas.width / (layers.length + 1);
    const maxNeurons = Math.max(...layers);
    const neuronRadius = 2; // Smaller neurons for better fit

    // Draw connections with reduced complexity
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
    ctx.lineWidth = 0.5;

    // Only draw connections for first few neurons to avoid performance issues
    for (let i = 0; i < layers.length - 1; i++) {
        const x1 = (i + 1) * layerSpacing;
        const x2 = (i + 2) * layerSpacing;

        // Draw fewer connections for performance
        const maxConnections = Math.min(10, layers[i]);
        for (let j = 0; j < maxConnections; j++) {
            const y1 = (neuralCanvas.height / (maxConnections + 1)) * (j + 1);

            const maxNextConnections = Math.min(10, layers[i + 1]);
            for (let k = 0; k < maxNextConnections; k++) {
                const y2 = (neuralCanvas.height / (maxNextConnections + 1)) * (k + 1);

                // Add some animation
                const alpha = 0.1 + Math.sin(Date.now() * 0.002 + j * 0.5 + k * 0.5) * 0.1;
                ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.stroke();
            }
        }
    }

    // Draw neurons (simplified representation)
    for (let i = 0; i < layers.length; i++) {
        const x = (i + 1) * layerSpacing;

        // Show representative neurons instead of all
        const neuronsToShow = Math.min(15, layers[i]);
        for (let j = 0; j < neuronsToShow; j++) {
            const y = (neuralCanvas.height / (neuronsToShow + 1)) * (j + 1);

            // Neuron glow effect
            const gradient = ctx.createRadialGradient(x, y, 0, x, y, neuronRadius * 3);
            gradient.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
            gradient.addColorStop(1, 'rgba(255, 255, 255, 0.1)');

            ctx.fillStyle = gradient;
            ctx.beginPath();
            ctx.arc(x, y, neuronRadius, 0, Math.PI * 2);
            ctx.fill();

            // Neuron border
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.7)';
            ctx.lineWidth = 1;
            ctx.stroke();
        }

        // Add layer label
        ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
        ctx.font = '10px Arial';
        ctx.textAlign = 'center';
        const label = i < layers.length - 1 ? `Hidden ${i + 1}` : 'Output';
        ctx.fillText(label, x, neuralCanvas.height - 10);
    }

    // Add some particle effects (reduced for performance)
    for (let i = 0; i < 3; i++) {
        const x = Math.random() * neuralCanvas.width;
        const y = Math.random() * neuralCanvas.height;
        const size = Math.random() * 1.5 + 0.5;

        ctx.fillStyle = `rgba(255, 255, 255, ${Math.random() * 0.3})`;
    if (isVisualizing) return;
    
    isVisualizing = true;
    startVizBtn.disabled = true;
    stopVizBtn.disabled = false;
    
    function animate() {
        drawNeuralNetwork();
        if (isVisualizing) {
            animationId = requestAnimationFrame(animate);
        }
    }
    
    animate();
}

function stopVisualization() {
    isVisualizing = false;
    startVizBtn.disabled = false;
    stopVizBtn.disabled = true;
    
    if (animationId) {
        cancelAnimationFrame(animationId);
        animationId = null;
    }
    
    // Clear canvas
    if (ctx) {
        ctx.clearRect(0, 0, neuralCanvas.width, neuralCanvas.height);
    }
}

// Update file list display
function updateFileList() {
    if (savedFiles.length === 0) {
        fileList.innerHTML = '<p class="no-files">No files saved yet</p>';
        return;
    }
    
    fileList.innerHTML = '';
    savedFiles.forEach((file, index) => {
        const fileItem = document.createElement('div');
        fileItem.className = 'file-item';
        fileItem.innerHTML = `
            <span class="file-name">${file.name}</span>
            <span class="file-language">${file.language.toUpperCase()} • ${file.timestamp}</span>
        `;
        
        fileItem.addEventListener('click', () => {
            // Remove active class from all items
            document.querySelectorAll('.file-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // Add active class to clicked item
            fileItem.classList.add('active');
            
            // Load file content
            codeOutput.value = file.code;
            languageSelect.value = file.language;
            codeOutput.readOnly = true;
            copyBtn.style.display = 'inline-block';
            downloadBtn.style.display = 'inline-block';
            saveBtn.style.display = 'inline-block';
            editBtn.style.display = 'inline-block';
        });
        
        fileList.appendChild(fileItem);
    });
}

// Event listeners
generateBtn.addEventListener('click', async () => {
    const prompt = promptTextarea.value.trim();
    const language = languageSelect.value;
    
    if (!prompt) {
        alert('Please enter a prompt.');
        return;
    }
    
    // Show loading state
    generateBtn.textContent = 'Training Neural Network...';
    generateBtn.disabled = true;
    
    try {
        // Add timeout to prevent hanging
        const timeoutPromise = new Promise((_, reject) => {
            setTimeout(() => reject(new Error('Generation timeout')), 30000); // 30 second timeout
        });
        
        const generationPromise = generateCodeWithNN(prompt, language, (status) => {
            generateBtn.textContent = status;
        });
        
        const generatedCode = await Promise.race([generationPromise, timeoutPromise]);
        codeOutput.value = generatedCode;
        codeOutput.readOnly = true;
        copyBtn.style.display = 'inline-block';
        downloadBtn.style.display = 'inline-block';
        saveBtn.style.display = 'inline-block';
        editBtn.style.display = 'inline-block';
        
        // Reset button
        generateBtn.textContent = 'Generate Code';
        generateBtn.disabled = false;
    } catch (error) {
        console.error('Error generating code:', error);
        if (error.message === 'Generation timeout') {
            alert('Code generation timed out. The neural network is too complex. Using fallback method.');
        } else {
            alert('Error generating code. Using fallback method.');
        }
        // Fallback to mock
        const generatedCode = generateCode(prompt, language);
        codeOutput.value = generatedCode;
        codeOutput.readOnly = true;
        copyBtn.style.display = 'inline-block';
        downloadBtn.style.display = 'inline-block';
        saveBtn.style.display = 'inline-block';
        editBtn.style.display = 'inline-block';
        generateBtn.textContent = 'Generate Code';
        generateBtn.disabled = false;
    }
});

editBtn.addEventListener('click', () => {
    const code = codeOutput.value;
    const language = languageSelect.value;
    
    if (!code.trim()) {
        alert('No code to edit.');
        return;
    }
    
    // Show loading state
    editBtn.textContent = 'Processing with Neural Network...';
    editBtn.disabled = true;
    
    // Simulate neural network processing time
    setTimeout(() => {
        const editedCode = editCodeWithNeuralNetwork(code, language);
        codeOutput.value = editedCode;
        codeOutput.readOnly = false; // Allow manual editing after AI edit
        
        // Reset button
        editBtn.textContent = 'Edit with Neural Network';
        editBtn.disabled = false;
    }, 1500); // 1.5 second delay to simulate neural network processing
});

copyBtn.addEventListener('click', () => {
    const code = codeOutput.value;
    navigator.clipboard.writeText(code).then(() => {
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
            copyBtn.textContent = 'Copy to Clipboard';
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy: ', err);
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = code;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
            copyBtn.textContent = 'Copy to Clipboard';
        }, 2000);
});

downloadBtn.addEventListener('click', () => {
    const code = codeOutput.value;
    const language = languageSelect.value;
    
    if (!code.trim()) {
        alert('No code to download.');
        return;
    }
    
    // Determine file extension based on language
    const extensions = {
        javascript: 'js',
        python: 'py',
        html: 'html',
        css: 'css',
        java: 'java',
        cpp: 'cpp',
    };
    
    const extension = extensions[language] || 'txt';
    const filename = `generated_code.${extension}`;
    
    // Create download link
    const blob = new Blob([code], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    // Show feedback
    const originalText = downloadBtn.textContent;
    downloadBtn.textContent = 'Downloaded!';
    setTimeout(() => {
        downloadBtn.textContent = 'Download File';
    }, 2000);
});

saveBtn.addEventListener('click', () => {
    const code = codeOutput.value;
    const language = languageSelect.value;
    
    if (!code.trim()) {
        alert('No code to save.');
        return;
    }
    
    // Generate filename
    const extensions = {
        javascript: 'js',
        python: 'py',
        html: 'html',
        css: 'css',
        java: 'java',
        cpp: 'cpp'
    };
    
    const extension = extensions[language] || 'txt';
    const timestamp = new Date().toISOString().slice(0, 19).replace(/:/g, '-');
    const filename = `generated_${timestamp}.${extension}`;
    
    // Save file
    const fileData = {
        name: filename,
        language: language,
        code: code,
        timestamp: new Date().toLocaleString()
    };
    
    savedFiles.push(fileData);
    updateFileList();
    
    // Show feedback
    const originalText = saveBtn.textContent;
    saveBtn.textContent = 'Saved!';
    setTimeout(() => {
        saveBtn.textContent = 'Save to Project';
    }, 2000);
});

// Canvas visualization event listeners
startVizBtn.addEventListener('click', startVisualization);
stopVizBtn.addEventListener('click', stopVisualization);

// Initialize model on page load
window.addEventListener('load', async () => {
    try {
        await initModel();
        console.log('Neural network initialized successfully');
    } catch (error) {
        console.error('Failed to initialize neural network:', error);
    }
});
});